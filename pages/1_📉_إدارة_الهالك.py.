import streamlit as st

st.markdown("<h2 style='text-align: right;'>📉 ميزان خسائر الهالك</h2>", unsafe_allow_html=True)

# تفاعل مباشر لصاحب المصنع
col1, col2 = st.columns(2)
with col1:
    price = st.number_input("سعر الخام (ج.م)", value=100)
with col2:
    weight = st.number_input("الكمية المهدرة (كيلو)", value=5)

loss = price * weight

if loss > 500:
    st.error(f"🚨 خسارة فادحة: أنت تخسر الآن {loss} جنيه!")
else:
    st.success(f"الخسارة الحالية: {loss} جنيه (ضمن النطاق)")
